# Cloudflare Pages headers
# Format: https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()

# Short cache for HTML so updates propagate fast
/*.html
  Cache-Control: public, max-age=60, s-maxage=60

# Data: short cache, revalidate quickly when hints.json changes
/hints.json
  Cache-Control: public, max-age=60, s-maxage=60

# Short cache for CSS/JS during the 6-day event — updates propagate fast
/*.css
  Cache-Control: public, max-age=60, s-maxage=60
/*.js
  Cache-Control: public, max-age=60, s-maxage=60
