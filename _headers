# Cloudflare Pages headers
# Format: https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()

# Short cache for HTML so updates propagate fast
/*.html
  Cache-Control: public, max-age=60, s-maxage=60

# Data: short cache, revalidate quickly when hints.json changes
/hints.json
  Cache-Control: public, max-age=60, s-maxage=60

# Long cache for static assets (CSS/JS) — bust by filename/query if needed
/*.css
  Cache-Control: public, max-age=3600, s-maxage=86400
/*.js
  Cache-Control: public, max-age=3600, s-maxage=86400
